{
  "expo": {
    "name": "HurdaMarket",
    "slug": "hurdamarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hurdamarket.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "İlan fotoğrafı çekmek için kamera gerekli.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotoğraf seçmek için gerekli.",
        "NSLocationWhenInUseUsageDescription": "Yakınımdaki ilanları göstermek için konum gerekli."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E12"
      },
      "package": "com.hurdamarket.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#BCF24A",
          "sounds": ["./assets/notification.wav"]
        }
      ],
      [
        "expo-camera",
        { "cameraPermission": "İlan fotoğrafı çekmek için kamera gerekli." }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "Yakınımdaki ilanları göstermek için konum gerekli." }
      ]
    ],
    "scheme": "hurdamarket",
    "extra": {
      "apiUrl": "http://localhost:5000/api",
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" }
    }
  }
}
