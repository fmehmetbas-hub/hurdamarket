# 🚀 HURDAMARKET CANLI (PRODUCTION) AYARLARI TASLAĞI
# Bu dosyadaki değerleri canlı sunucunuzun (örn: Render.com Dashboard) 'Environment Variables' kısmına ekleyin.

# 1. Veritabanı (Render/DigitalOcean Managed PostgreSQL)
# Örnek: postgresql://user:pass@host:port/dbname
DATABASE_URL=

# 2. Güvenlik
# Canlıda yerel olandan farklı, çok karmaşık bir anahtar girin.
JWT_SECRET=
JWT_EXPIRES_IN=30d

# 3. Ortam
NODE_ENV=production
PORT=10000

# 4. Domain / URL Ayarları
# Örnek: https://hurdamarket.com
FRONTEND_URL=
BACKEND_URL=

# 5. SMS (Netgsm - Gerçek Anahtarlar)
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=HRDAMRKET

# 6. Ödeme (Stripe / Iyzico - Canlı Anahtarlar)
# TEST anahtarlarını DEĞİL, 'sk_live_' ile başlayan anahtarları girin.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# 7. Komisyon Oranı
COMMISSION_RATE=4

# 8. Logo & Görseller (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
