# Veritabanı
DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/hurdamarket

# JWT
JWT_SECRET=buraya-cok-uzun-rastgele-bir-string-yaz
JWT_EXPIRES_IN=7d

# Cloudinary (fotoğraf yükleme)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMS (Netgsm veya Twilio)
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=HURDAMARKET

# Sunucu
PORT=5000
NODE_ENV=development

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
COMMISSION_RATE=4

# Redis (opsiyonel - cache için)
REDIS_URL=redis://localhost:6379

# Sentry (opsiyonel - hata takibi)
SENTRY_DSN=https://xxx@sentry.io/xxx
